# Copy to .env for local runs. In production these become:
#   - Vercel project Environment Variables (webhook)
#   - GitHub Actions repository Secrets (worker)
# See README.md for which surface needs which variables.

# --- Telegram Bot API (the bot users talk to) ---
# From @BotFather.
BOT_TOKEN=123456:ABC-DEF...

# Shared secret added to the webhook URL so only Telegram can call it.
# Any random string; must match what you pass to scripts/set_webhook.py.
WEBHOOK_SECRET=change-me-to-a-long-random-string

# --- Telegram user account (the scraper, MTProto via Telethon) ---
# From https://my.telegram.org -> API development tools.
TELEGRAM_API_ID=1234567
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef
# Generated once by `python scripts/login_telethon.py` (string session).
TELETHON_SESSION=

# --- Supabase ---
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=
# Use the SERVICE ROLE key (server-side only; never ship to a client).
SUPABASE_SERVICE_KEY=

# --- Google Gemini (embeddings) ---
# From https://aistudio.google.com/app/apikey (free tier, no card).
GEMINI_API_KEY=

# --- Tunables (optional; defaults live in core/config.py) ---
# SIMILARITY_THRESHOLD=0.70
# MAX_LOOKBACK_DAYS=90
# MIN_NEAR_LIVE_MINUTES=5
# BETA_MAX_USERS=5
# MAX_MATCH_PROFILE_WORDS=35
# SCRAPE_MAX_MESSAGES=0        # 0 = scrape until lookback boundary
# SCRAPE_PROGRESS_EVERY=250    # log progress while scanning busy sources
# JOB_STALE_MINUTES=20       # retry jobs abandoned by canceled workers

# --- OCR (worker only) ---
# Defaults assume English poster images. For more languages, install the matching
# tesseract-ocr-<lang> package in the GitHub workflow and set OCR_LANGS, e.g.
# OCR_LANGS=eng+amh
# OCR_TIMEOUT_SECONDS=8
# OCR_TESSERACT_CONFIG=--psm 6
