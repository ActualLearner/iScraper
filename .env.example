# Copy to .env for local runs. In production these become:
#   - Vercel project Environment Variables (webhook)
#   - GitHub Actions repository Secrets or Heroku Config Vars (worker)
# See README.md for which surface needs which variables.

# --- Telegram Bot API (the bot users talk to) ---
# From @BotFather.
BOT_TOKEN=123456:ABC-DEF...

# Shared secret added to the webhook URL so only Telegram can call it.
# Any random string; must match what you pass to scripts/set_webhook.py.
WEBHOOK_SECRET=change-me-to-a-long-random-string

# --- Telegram user account (the scraper, MTProto via Telethon) ---
# From https://my.telegram.org -> API development tools.
TELEGRAM_API_ID=1234567
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef
# Generated once by `python scripts/login_telethon.py` (string session).
TELETHON_SESSION=

# --- Supabase ---
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=
# Use the SERVICE ROLE key (server-side only; never ship to a client).
SUPABASE_SERVICE_KEY=

# --- Embeddings (local, worker only) ---
# Runs on CPU inside the worker via fastembed; no API key or network at runtime.
# The model is baked into the Docker image at build time. Defaults live in
# core/config.py; override here only to swap models or tune memory.
# EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
# EMBEDDING_DIM=768                 # nomic native; lower = Matryoshka (also alter DB)
# EMBEDDING_QUERY_PREFIX=search_query:      # trailing space matters; nomic requires it
# EMBEDDING_DOCUMENT_PREFIX=search_document:
# EMBEDDING_BATCH=16                # texts per batch; main lever on peak RAM
# EMBEDDING_DB_PAGE=200            # unembedded posts pulled per DB page
# EMBEDDING_THREADS=0              # >0 caps onnxruntime CPU threads (less RAM/CPU)
# EMBEDDING_BACKLOG_RETRY_MINUTES=5 # resume an unfinished backfill next run

# --- Tunables (optional; defaults live in core/config.py) ---
# SIMILARITY_THRESHOLD=0.70
# MAX_LOOKBACK_DAYS=90
# MIN_NEAR_LIVE_MINUTES=5
# BETA_MAX_USERS=5
# MAX_MATCH_PROFILE_WORDS=35
# SCRAPE_MAX_MESSAGES=0              # 0 = scrape until lookback boundary
# SCRAPE_PROGRESS_EVERY=250          # log progress while scanning busy sources
# SCRAPE_GROUP_BATCH_SIZE=50         # DB lookup/insert batch size while scraping
# PAST_SEARCH_JOBS_PER_RUN=1         # keep scheduled runs responsive
# WORKER_RUN_TIMEOUT_SECONDS=0       # 0 = no app-level worker pass timeout
# WORKER_STAGE_TIMEOUT_SECONDS=0     # 0 = no per-stage timeout
# WORKER_LOOP_INTERVAL_SECONDS=300  # persistent worker sleep between passes
# JOB_STALE_MINUTES=20               # retry jobs abandoned by canceled workers
# SUPABASE_DB_RETRIES=3             # retry transient Supabase/httpx transport drops
# SUPABASE_DB_RETRY_BACKOFF_SECONDS=1
# SUPABASE_DB_RETRY_JOB_MINUTES=2

# --- OCR (worker only) ---
# Defaults assume English poster images. For more languages, install the matching
# tesseract-ocr-<lang> package in the GitHub workflow and set OCR_LANGS, e.g.
# OCR_LANGS=eng+amh
# OCR_ENABLED=true
# OCR_TIMEOUT_SECONDS=10
# OCR_DOWNLOAD_TIMEOUT_SECONDS=30
# OCR_TESSERACT_CONFIG=--psm 6
# OCR_MAX_IMAGES_PER_POST=3
# OCR_MAX_IMAGE_MB=5
# OCR_MAX_IMAGE_PIXELS=6000000
# OCR_MAX_IMAGE_DIMENSION=1600
# OCR_MAX_TEXT_CHARS=6000
# OCR_SKIP_WHEN_CAPTION_PRESENT=false
# OCR_THREAD_LIMIT=1
